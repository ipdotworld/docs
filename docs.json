{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ip.world",
  "description": "User and developer documentation for ip.world — trends, tokens, trading, rewards, and integrations.",
  "colors": {
    "primary": "#AD74FE",
    "light": "#C093FF",
    "dark": "#321F4D"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FFFFFF",
      "dark": "#0D0D0D"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "FAQ",
          "icon": "circle-question-mark",
          "href": "/user-guides/reference/faq"
        },
        {
          "anchor": "Glossary",
          "icon": "book-open",
          "href": "/user-guides/reference/glossary"
        },
        {
          "anchor": "Account & settings",
          "icon": "user",
          "href": "/user-guides/account/sign-in-methods"
        },
        {
          "anchor": "Safety",
          "icon": "shield",
          "href": "/user-guides/safety/reporting"
        }
      ]
    },
    "tabs": [
      {
        "tab": "User guide",
        "groups": [
          {
            "group": "GETTING STARTED",
            "pages": ["index", "user-guides/getting-started"]
          },
          {
            "group": "CORE CONCEPTS",
            "pages": [
              "user-guides/trends-and-tokens",
              "user-guides/trading/payment-methods",
              "user-guides/rewards/holder-rewards",
              "user-guides/rewards/ugc-program",
              "user-guides/manage/treasury-and-proposals",
              "user-guides/verification/verification-overview",
              "user-guides/rewards/overview"
            ]
          },
          {
            "group": "HOW-TO GUIDES",
            "pages": [
              "user-guides/trading/overview",
              "user-guides/how-to/launch-a-coin",
              "user-guides/how-to/earn-holder-rewards",
              "user-guides/how-to/earn-ugc-rewards",
              "user-guides/how-to/verify-a-coin"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "Overview",
            "pages": ["dev/index"]
          },
          {
            "group": "Platform",
            "pages": ["dev/authentication", "dev/api", "dev/webhooks"]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/user-guides/ips-and-tokens", "destination": "/user-guides/trends-and-tokens" },
    { "source": "/user-guides/app-tour", "destination": "/user-guides/platform-map" },
    { "source": "/user-guides/account/login-and-wallets", "destination": "/user-guides/account/sign-in-methods" },
    { "source": "/user-guides/account/connecting-socials", "destination": "/user-guides/account/connecting-x" },
    { "source": "/user-guides/explore/navigating-ips", "destination": "/user-guides/explore/navigating-trends" },
    { "source": "/user-guides/explore/feeds", "destination": "/user-guides/explore/social-feeds" },
    { "source": "/user-guides/explore/search-and-filters", "destination": "/user-guides/explore/search-filters-and-sort" },
    { "source": "/user-guides/explore/virality-score", "destination": "/user-guides/explore/virality" },
    { "source": "/user-guides/create/creating-an-ip", "destination": "/user-guides/launch/create-a-trend" },
    { "source": "/user-guides/create/creating-a-token", "destination": "/user-guides/launch/create-a-token" },
    { "source": "/user-guides/create/metadata-socials-and-antisnipe", "destination": "/user-guides/launch/metadata-socials-and-antisnipe" },
    { "source": "/user-guides/verification/creator-vs-community-ips", "destination": "/user-guides/verification/creator-vs-community-trends" },
    { "source": "/user-guides/verification/claiming-a-creator-ip", "destination": "/user-guides/verification/claiming-a-creator-trend" },
    { "source": "/user-guides/manage/creator-ip-management", "destination": "/user-guides/manage/trend-owner-dashboard" },
    { "source": "/user-guides/reference/reporting-and-moderation", "destination": "/user-guides/safety/reporting" },
    { "source": "/user-guides/growth/referrals", "destination": "/user-guides/rewards/referrals" },
    { "source": "/user-guides/rewards/rewards-and-points", "destination": "/user-guides/rewards/points-and-leaderboard" },
    { "source": "/user-guides/rewards/leaderboard", "destination": "/user-guides/rewards/points-and-leaderboard" },
    { "source": "/user-guides/manage/community-ip-governance", "destination": "/user-guides/manage/community-governance" }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://ip.world"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity"]
  },
  "footer": {}
}
